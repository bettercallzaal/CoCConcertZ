# Firebase Client SDK
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Local Firestore/Auth emulator (set to "true" to point the client SDK
# at the local emulator on 127.0.0.1:8080 / 9099). See firebase.json.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=

# Firebase App Check — reCAPTCHA v3 site key. Once set, uncomment the
# initializeAppCheck block in src/lib/firebase.ts. See docs/app-check-setup.md.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Cloudinary (replaces Firebase Storage for all uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Wallet Gate — Set to "false" to disable wallet token requirement for archive uploads (for events/pilots)
NEXT_PUBLIC_WALLET_GATE_ENABLED=true

# Auth passcodes
ADMIN_PASSCODE=
# Per-artist passcodes: JSON map of { passcode: artistSlug }
# Generate unique 5-letter lowercase codes for each artist
ARTIST_PASSCODES={"xkmpq":"joseph-goats","rvtnw":"stilo","bjhcf":"tom-fellenz"}
